<Window x:Class="smallTV.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:smallTV"
        mc:Ignorable="d"
        Title="Small TV" Height="280" Width="250"
        KeyDown="Window_KeyDown"
        Loaded="Window_Loaded">
    <Grid>
        <Label Content="Open/Hide menu keys" FontFamily="HP Simplified" HorizontalAlignment="Left" Margin="20,20,0,0" Height="25" Width="120" VerticalAlignment="Top"/>
        <Button Name="ResetMenuKeysButton" Click="ResetMenuKeysButton_Click" HorizontalAlignment="Left" Margin="40,50,0,0" VerticalAlignment="Top" Height="20" Width="80" BorderThickness="0">
            <Image Source="/Images/Reset.png" Stretch="Fill"/>
        </Button>
        <Label Name="MenuKeysLabel" Content="Key1+Key2+Key3" FontFamily="HP Simplified" HorizontalAlignment="Left" Margin="130,47,0,0" Height="25" VerticalAlignment="Top"/>


        <Label Content="Open/Hide tv keys" FontFamily="HP Simplified" HorizontalAlignment="Left" Margin="20,80,0,0" Height="25" Width="120" VerticalAlignment="Top"/>
        <Button Name="ResetTVKeysButton" Click="ResetTVKeysButton_Click" HorizontalAlignment="Left" Margin="40,110,0,0" VerticalAlignment="Top" Height="20" Width="80" BorderThickness="0">
            <Image Source="/Images/Reset.png" Stretch="Fill"/>
        </Button>
        <Label Name="TVKeysLabel" Content="Key1+Key2+Key3" FontFamily="HP Simplified" HorizontalAlignment="Left" Margin="130,107,0,0" Height="25" VerticalAlignment="Top"/>


        <Label Content="Panic keys" FontFamily="HP Simplified" HorizontalAlignment="Left" Margin="20,140,0,0" Height="25" Width="120" VerticalAlignment="Top"/>
        <Button Name="ResetPanicKeysButton" Click="ResetPanicKeysButton_Click" HorizontalAlignment="Left" Margin="40,170,0,0" VerticalAlignment="Top" Height="20" Width="80" BorderThickness="0">
            <Image Source="/Images/Reset.png" Stretch="Fill"/>
        </Button>
        <Label Name="PanicKeysLabel" Content="Key1+Key2+Key3" FontFamily="HP Simplified" HorizontalAlignment="Left" Margin="130,167,0,0" Height="25" VerticalAlignment="Top"/>

        
        <Label Name="SelectedWindowLabel" Content="Current Window" FontFamily="HP Simplified" HorizontalAlignment="Left" Margin="75,205,0,0" Height="25" FontSize="14" Width="120" VerticalAlignment="Top"/>
        <Button Name="SelectWindowButton" Click="SelectWindowButton_Click" HorizontalAlignment="Left" Margin="85,230,0,0" VerticalAlignment="Top" Height="20" Width="80" BorderThickness="0">
            <Image Source="/Images/Select.png" Stretch="Fill"/>
        </Button>

    </Grid>
</Window>
